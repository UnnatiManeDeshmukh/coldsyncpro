# ═══════════════════════════════════════════════════════════
#  ColdSync Pro — Environment Configuration Template
#  Copy this file to .env and fill in your values
# ═══════════════════════════════════════════════════════════

# ── Core ─────────────────────────────────────────────────────
# Generate a strong key: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-secret-key-here

# Development: True | Production: False
DEBUG=True

# Development: localhost,127.0.0.1 | Production: yourdomain.com,www.yourdomain.com
ALLOWED_HOSTS=localhost,127.0.0.1

# ── CORS ─────────────────────────────────────────────────────
# Development: False (uses list below) | Production: False
CORS_ALLOW_ALL_ORIGINS=False
# Add your frontend URL(s) — comma separated
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# Production example: CORS_ALLOWED_ORIGINS=https://yourdomain.com

# ── Database ─────────────────────────────────────────────────
# Default: SQLite (works out of the box for development)
# For PostgreSQL (recommended for production):
#   1. Install PostgreSQL
#   2. Create database: createdb coldsync_db
#   3. Uncomment and fill the lines below
# DB_ENGINE=django.db.backends.postgresql
# DB_NAME=coldsync_db
# DB_USER=postgres
# DB_PASSWORD=your-strong-password
# DB_HOST=localhost
# DB_PORT=5432

# ── Email (Gmail SMTP) ───────────────────────────────────────
# 1. Enable 2FA on Gmail
# 2. Go to Google Account > Security > App Passwords
# 3. Generate App Password for "Mail"
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-gmail@gmail.com
EMAIL_HOST_PASSWORD=your-16-char-app-password
DEFAULT_FROM_EMAIL=ColdSync Pro <your-gmail@gmail.com>
ADMIN_EMAIL=your-gmail@gmail.com

# ── UPI Payment ──────────────────────────────────────────────
UPI_ID=yourname@upi
UPI_NAME=Your Agency Name
UPI_QR_IMAGE=upi-qr.png

# ── WhatsApp via Twilio (optional) ───────────────────────────
# Sign up at https://www.twilio.com/try-twilio
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_SMS_FROM=+1XXXXXXXXXX
AGENCY_WHATSAPP_NUMBER=+91XXXXXXXXXX

# ── SMS via Fast2SMS (Indian, free tier) ─────────────────────
# Get free API key at: https://www.fast2sms.com/
FAST2SMS_API_KEY=your-fast2sms-api-key

# ── AI Chatbot (Groq — free tier) ────────────────────────────
# Get free API key at: https://console.groq.com
GROQ_API_KEY=your-groq-api-key

# ── Production SSL (only when DEBUG=False + HTTPS) ───────────
# SECURE_SSL_REDIRECT=True

# ── Security (production hardening) ─────────────────────────
# These are auto-applied when DEBUG=False. Override here if needed.
# SESSION_COOKIE_SECURE=True
# CSRF_COOKIE_SECURE=True

# ── File Upload Limits ───────────────────────────────────────
# Max image upload: 5MB (product images, QR codes)
# Configured in settings.py — change FILE_UPLOAD_MAX_MEMORY_SIZE to override

# ── Cache (optional Redis for production) ────────────────────
# Install: pip install django-redis
# Local Redis: redis://127.0.0.1:6379/1
# Redis Cloud: redis://:password@host:port/0
# REDIS_URL=redis://127.0.0.1:6379/1
